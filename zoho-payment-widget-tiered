<script>
(function() {
    const SURCHARGE = 0.03;
    const DISCOUNT_END_DATE = new Date('2026-03-31T23:59:59'); // Set your discount end date here
    const DISCOUNT_ACTIVE = new Date() <= DISCOUNT_END_DATE;
    
    let tier = null, langs = new Set(), otherLangText = '', surveyMethod = 'online', method = 'credit_card';
    
    const $ = id => document.getElementById(id);
    const fmt = v => new Intl.NumberFormat('en-US',{style:'currency',currency:'USD'}).format(v);
    
    function calc() {
        if(!tier) return {sub:0,sur:0,tot:0};
        
        // Use discount or regular price based on date
        let sub = DISCOUNT_ACTIVE 
            ? parseFloat(tier.dataset.dashD) 
            : parseFloat(tier.dataset.dashR);
            
        if(surveyMethod === 'paper') sub += parseFloat(tier.dataset.pap);
        
        // Add language costs (other language is free)
        langs.forEach(l => {
            if(l !== 'other') sub += 199;
        });
        
        const sur = method === 'credit_card' ? sub * SURCHARGE : 0;
        return {sub, sur, tot:sub + sur};
    }
    
    function updateLines() {
        if(!tier) {
            $('bpw_lines').innerHTML = '<div class="bpw-empty">Please select your company size to continue</div>';
            return;
        }
        
        const lines = [];
        const t = tier.dataset.tier, e = tier.dataset.emp;
        const df = DISCOUNT_ACTIVE ? parseFloat(tier.dataset.dashD) : parseFloat(tier.dataset.dashR);
        const dr = parseFloat(tier.dataset.dashR);
        
        lines.push(`<div class="bpw-line"><span>Dashboard Fee (${t} emp, ${e} surveyed)</span><span class="amt">${fmt(df)}</span></div>`);
        
        if(DISCOUNT_ACTIVE) {
            lines.push(`<div class="bpw-line bpw-line-note"><span>Regular: ${fmt(dr)} - 15% discount applied</span></div>`);
        }
        
        if(surveyMethod === 'online') {
            lines.push(`<div class="bpw-line"><span>Online Survey</span><span class="amt">Free</span></div>`);
        } else if(surveyMethod === 'paper') {
            const pf = parseFloat(tier.dataset.pap);
            lines.push(`<div class="bpw-line"><span>Paper Survey Fee</span><span class="amt">${fmt(pf)}</span></div>`);
        }
        
        if(langs.size > 0) {
            const languageNames = [];
            langs.forEach(l => {
                if(l === 'other') {
                    languageNames.push(`Other: ${otherLangText || 'Not specified'}`);
                } else {
                    const el = document.querySelector(`[data-lang="${l}"] .bpw-name`);
                    if(el) languageNames.push(el.textContent);
                }
            });
            
            // Count paid languages (not including 'other')
            const paidLangCount = Array.from(langs).filter(l => l !== 'other').length;
            const langCost = paidLangCount * 199;
            
            lines.push(`<div class="bpw-line"><span>Languages: ${languageNames.join(', ')}</span><span class="amt">${langCost > 0 ? fmt(langCost) : 'Free'}</span></div>`);
        }
        
        $('bpw_lines').innerHTML = lines.join('');
    }
    
    function update() {
        const {sub, sur, tot} = calc();
        $('bpw_sub').textContent = fmt(sub);
        $('bpw_sur').textContent = fmt(sur);
        $('bpw_tot').textContent = fmt(tot);
        updateLines();
        
        // Update Zoho hidden fields
        const set = (n,v) => {const f = document.querySelector(`[name="${n}"]`); if(f) f.value = v};
        set('subtotal_amount', sub.toFixed(2));
        set('surcharge_amount', sur.toFixed(2));
        set('total_amount', tot.toFixed(2));
        set('payment_method', method);
        if(tier) {
            set('company_size', tier.dataset.tier);
            set('employees_surveyed', tier.dataset.emp);
            set('dashboard_fee', tier.dataset.dashD);
            set('paper_fee', surveyMethod === 'paper' ? tier.dataset.pap : '0');
        }
        set('survey_method', surveyMethod);
        
        // Format selected languages for hidden field
        const langList = [];
        langs.forEach(l => {
            if(l === 'other') {
                langList.push(`Other: ${otherLangText || 'Not specified'}`);
            } else {
                const el = document.querySelector(`[data-lang="${l}"] .bpw-name`);
                if(el) langList.push(el.textContent);
            }
        });
        set('selected_languages', langList.join(', '));
        
        const show = method === 'credit_card' && sub > 0;
        $('bpw_sur_row').classList.toggle('show', show);
        $('bpw_notice').classList.toggle('show', show);
        
        $('bpw_btn').disabled = !tier;
        
        if(tier) $('bpw_paper').textContent = fmt(parseFloat(tier.dataset.pap));
    }
    
    // Company size selection
    document.querySelectorAll('.company-size-radio').forEach(el => {
        el.addEventListener('click', () => {
            document.querySelectorAll('.company-size-radio').forEach(r => r.classList.remove('sel'));
            el.classList.add('sel');
            tier = el;
            update();
        });
    });
    
    // Survey method selection
    document.querySelectorAll('.survey-method-radio').forEach(el => {
        el.addEventListener('click', () => {
            document.querySelectorAll('.survey-method-radio').forEach(s => s.classList.remove('sel'));
            el.classList.add('sel');
            surveyMethod = el.dataset.method;
            update();
        });
    });
    
    // Language selection
    document.querySelectorAll('[data-lang]').forEach(el => {
        el.addEventListener('click', function() {
            const l = el.dataset.lang;
            const isOther = l === 'other';
            
            if(langs.has(l)) {
                langs.delete(l);
                this.classList.remove('chk');
                
                // Hide text input if unchecking "Other"
                if(isOther) {
                    $('other-lang-input').style.display = 'none';
                    otherLangText = '';
                }
            } else {
                langs.add(l);
                this.classList.add('chk');
                
                // Show text input if checking "Other"
                if(isOther) {
                    $('other-lang-input').style.display = 'block';
                    $('other-lang-input').focus();
                }
            }
            update();
        });
    });
    
    // Other language text input
    $('other-lang-input').addEventListener('input', function() {
        otherLangText = this.value.trim();
        update();
    });
    
    // Payment method
    document.querySelectorAll('[name="bpw_method"]').forEach(el => {
        el.addEventListener('change', e => {
            method = e.target.value;
            update();
        });
    });
    
    // Payment button
    $('bpw_btn').addEventListener('click', () => {
        const {sub, sur, tot} = calc();
        alert(`Payment Summary:\n\nSubtotal: ${fmt(sub)}\nSurcharge: ${fmt(sur)}\nTotal: ${fmt(tot)}\n\nIn production, this would redirect to Zoho Payments.`);
    });
    
    // Initialize discount display
    function initDiscountDisplay() {
        document.querySelectorAll('.company-size-radio').forEach(el => {
            const pricing = el.querySelector('.bpw-pricing');
            const simple = el.querySelector('.bpw-price-simple');
            
            if(DISCOUNT_ACTIVE) {
                if(pricing) pricing.classList.remove('hide');
                if(simple) simple.classList.remove('show');
            } else {
                if(pricing) pricing.classList.add('hide');
                if(simple) simple.classList.add('show');
            }
        });
    }
    
    initDiscountDisplay();
    update();
})();
</script>
