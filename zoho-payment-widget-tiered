.bpw-radio.sel .bpw-circle::after{display:block}
.bpw-info{flex:1}
.bpw-name{font-weight:500;color:#1a1a1a;font-size:14px;margin-bottom:2px}
.bpw-desc{font-size:12px;color:#6c757d}
.bpw-pricing{display:flex;flex-direction:column;align-items:flex-end}
